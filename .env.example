# 复制为 .env 后填写，切勿提交 .env 到 Git

# 云端总控台
PORT=4790
HOST=127.0.0.1
NODE_ENV=production
SESSION_SECRET=请换成随机长字符串
SECRET_ENCRYPTION_KEY=请换成32字节base64密钥
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
SERVICE_TOKEN=供其他项目调用 /api/secrets/resolve 的服务令牌

# 本地 Agent（连接云端时请改 CONTROL_SERVER_URL）
AGENT_NAME=公司电脑Agent
AGENT_TOKEN=dev-agent-token-change-me
SCAN_ROOT=E:\我的软件源码
CONTROL_SERVER_URL=http://127.0.0.1:4790

# 阿里云部署（仅 deploy 脚本使用，勿提交）
# SSH_PASS=你的SSH密码
# DEPLOY_HOST=8.137.126.18
