# 复制为 .env 后填写，切勿提交 .env 到 Git

# ── 本地开发（control-server）──
PORT=4790
HOST=127.0.0.1
NODE_ENV=development
SESSION_SECRET=请换成随机长字符串
SECRET_ENCRYPTION_KEY=请换成32字节base64密钥
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
SERVICE_TOKEN=供千帆上传与其他项目调用 /api/secrets 的服务令牌

# ── 本地 Agent ──
# 本地开发 server：
# CONTROL_SERVER_URL=http://127.0.0.1:4790
# 正式连接云端（域名未备案前统一用单 IP，不要使用域名和 wss）：
CONTROL_SERVER_URL=http://8.137.126.18/control
AGENT_NAME=公司电脑Agent
AGENT_TOKEN=与云端 .env 中 AGENT_TOKEN 一致
SCAN_ROOT=E:\我的软件源码

# WebSocket（Agent 自动拼接）：ws://8.137.126.18/control/api/agent/ws

# ── 阿里云部署（仅 deploy 脚本使用，勿提交）──
# SSH_PASS=你的SSH密码
# DEPLOY_HOST=8.137.126.18
