{
  "name": "zhubo-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "珠宝项目总控台 Zhubo Control Center",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @zhubo/control-server\" \"npm run dev -w @zhubo/control-web\"",
    "dev:server": "npm run dev -w @zhubo/control-server",
    "dev:web": "npm run dev -w @zhubo/control-web",
    "dev:agent": "npm run dev -w @zhubo/control-agent",
    "dev:desktop": "npm run dev -w @zhubo/control-desktop",
    "build": "npm run build -w @zhubo/control-shared && npm run build -w @zhubo/control-web && npm run build -w @zhubo/control-server",
    "build:desktop": "npm run build -w @zhubo/control-desktop",
    "pack:desktop": "npm run pack -w @zhubo/control-desktop",
    "pack:desktop:clean": "node scripts/pack-desktop-clean.mjs",
    "pack:desktop:fresh": "npm run build -w @zhubo/control-desktop && npm run pack -w @zhubo/control-desktop -- --config.directories.output=dist-desktop-pack",
    "start": "npm run start -w @zhubo/control-server",
    "db:generate": "npm run db:generate -w @zhubo/control-server",
    "db:push": "npm run db:push -w @zhubo/control-server",
    "db:seed": "npm run db:seed -w @zhubo/control-server",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "check": "npm run format:check && npm run build",
    "control:init-project": "node scripts/init-project.mjs",
    "control:acceptance-scan": "node scripts/acceptance-scan.mjs",
    "control:acceptance-import": "node scripts/acceptance-import.mjs",
    "control:acceptance-steward": "node scripts/acceptance-steward.mjs",
    "control:acceptance-desktop-performance": "node scripts/acceptance-desktop-performance.mjs",
    "control:acceptance-ops-scripts": "node scripts/acceptance-ops-scripts.mjs",
    "control:patch-risk-levels": "node scripts/patch-risk-levels.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2"
  }
}
