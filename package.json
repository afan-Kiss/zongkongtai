{
  "name": "zhubo-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "珠宝本地总控工作台",
  "workspaces": [
    "apps/control-desktop",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev -w @zhubo/control-desktop",
    "build": "npm run build -w @zhubo/control-shared && npm run build -w @zhubo/control-desktop",
    "build:desktop": "npm run build -w @zhubo/control-desktop",
    "pack:desktop": "npm run pack -w @zhubo/control-desktop",
    "pack:desktop:clean": "node scripts/pack-desktop-clean.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "check": "npm run format:check && npm run build",
    "control:acceptance-desktop-performance": "node scripts/acceptance-desktop-performance.mjs",
    "control:acceptance-port-conflicts": "node scripts/acceptance-port-conflicts.mjs",
    "control:acceptance-local-mode": "node scripts/acceptance-local-mode.mjs",
    "control:acceptance-final-local-clean": "node scripts/acceptance-final-local-clean.mjs",
    "control:acceptance-external-running": "node scripts/acceptance-external-running.mjs",
    "control:acceptance-overview-no-auto-git": "node scripts/acceptance-overview-no-auto-git.mjs",
    "control:acceptance-external-stop": "node scripts/acceptance-external-stop.mjs",
    "control:acceptance-start-command": "node scripts/acceptance-start-command.mjs",
    "control:acceptance-minimal-local": "node scripts/acceptance-minimal-local.mjs",
    "control:acceptance-local-only": "node scripts/acceptance-local-only.mjs",
    "control:acceptance-source-format": "node scripts/acceptance-source-format.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2"
  }
}
