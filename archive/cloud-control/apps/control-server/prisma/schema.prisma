generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  description    String?
  category       String?
  locationType   String   @default("local")
  localPath      String?
  serverPath     String?
  gitRemote      String?
  branch         String?
  packageManager String   @default("unknown")
  startCommand   String?
  devCommand     String?
  desktopStartCommand String?
  buildCommand   String?
  deployCommand  String?
  pm2Name        String?
  healthUrl      String?
  localWebUrl    String?
  localHealthUrl String?
  publicUrl      String?
  internalUrl    String?
  status         String   @default("unknown")
  owner          String?
  notes          String?
  lastScannedAt  DateTime?
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ports         PortUsage[]
  commands      CommandProfile[]
  healthResults HealthCheckResult[]
}

model PortUsage {
  id                String   @id @default(cuid())
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  port              Int
  protocol          String   @default("http")
  host              String   @default("127.0.0.1")
  sourceFile        String?
  sourceLine        Int?
  sourceType        String   @default("manual")
  purpose           String?
  role              String   @default("unknown")
  conflictReason    String?
  isRuntimeDetected Boolean  @default(false)
  runtimeStatus     String?
  agentId           String?
  pid               Int?
  processName       String?
  lastSeenAt        DateTime?
  conflictLevel     String   @default("none")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([port])
  @@index([projectId])
  @@index([agentId, port])
  @@index([conflictLevel])
}

model SecretStore {
  id              String    @id @default(cuid())
  scope           String    @default("shop")
  platform        String
  shopName        String?
  rawShopName     String?
  shopId          String?
  accountName     String?
  keyName         String
  encryptedValue  String
  valuePreview    String
  cookieHash      String?
  expiresAt       DateTime?
  lastValidatedAt DateTime?
  lastSeenAt      DateTime?
  capturedAt      DateTime?
  lastUploadedBy  String?
  collectorMachine String?
  collectorSource String?
  autoUpdated     Boolean   @default(false)
  status          String    @default("unknown")
  notes           String?
  archived        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([platform, shopName, keyName])
}

model CommandProfile {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  command   String
  cwd       String?
  envJson   String?
  type      String   @default("dev")
  agentId   String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Agent {
  id          String    @id @default(cuid())
  name        String
  machineName String?
  os          String?
  basePath    String?
  tokenHash   String
  status      String    @default("offline")
  lastSeenAt  DateTime?
  version     String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OperationLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  targetType String?
  targetId   String?
  detailJson String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model HealthCheckResult {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url        String
  statusCode Int?
  ok         Boolean  @default(false)
  message    String?
  latencyMs  Int?
  checkedAt  DateTime @default(now())

  @@index([projectId, checkedAt])
}

model SecretAccessLog {
  id         String   @id @default(cuid())
  actor      String
  platform   String
  shopName   String?
  keyName    String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}
